[Unit]
Description=Xray - VLESS Reality
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/data/xray
ExecStart=/data/xray/xray run -c /data/xray/config.json
Restart=on-failure
RestartSec=5s
LimitNOFILE=1048576
LimitNPROC=512

[Install]
WantedBy=multi-user.target
